#!/usr/bin/env bash
set -Eeuo pipefail

COMMAND="${1:-status}"
HOST_NAME="${JIM_PROD_SSH:-ksp@192.168.20.105}"
PROD_URL="${JIM_PROD_URL:-http://192.168.20.105:5101}"
BRANCH="${JIM_PROD_BRANCH:-main}"

SUDO_HELP="Prod sudo permissions may need to be refreshed. Run: bash scripts/prod deploy, then bash scripts/prod repair-sudo"

prod_ssh() {
  ssh "$HOST_NAME" "$@"
}

run_remote() {
  local command="$1"

  if ! prod_ssh "$command"; then
    echo
    echo "$SUDO_HELP"
    return 1
  fi
}

redeploy_remote() {
  run_remote "git --work-tree=/opt/jim-site/app --git-dir=/srv/git/jim-site.git checkout -f $BRANCH && cd /opt/jim-site/app && bash deploy/ubuntu/deploy.sh"
}

require_clean_deploy_tree() {
  local dirty

  dirty="$(git status --porcelain)"

  if [[ -n "$dirty" ]]; then
    echo "There are local changes that are not committed, so deploy would not include them."
    echo
    echo "$dirty"
    echo
    echo "Commit the changes first, then run: bash scripts/prod deploy"
    return 1
  fi
}

show_status() {
  python3 - "$PROD_URL" <<'PY'
import sys
import urllib.request

url = sys.argv[1]
try:
    with urllib.request.urlopen(url, timeout=5) as response:
        print(f"Frontend: online ({response.status})")
        print(f"URL:      {url}")
except Exception as exc:
    print(f"Frontend is unreachable at {url}")
    print(exc)
    raise SystemExit(1)
PY
}

case "$COMMAND" in
  status|health)
    show_status
    ;;
  reload)
    run_remote "sudo /usr/sbin/nginx -t && sudo /usr/bin/systemctl reload nginx"
    echo "Nginx reloaded."
    ;;
  repair-sudo)
    run_remote "sudo /usr/local/sbin/jim-site-install-system-config"
    echo "Prod sudo permissions refreshed."
    ;;
  redeploy)
    redeploy_remote
    ;;
  deploy|update)
    require_clean_deploy_tree
    git push prod "HEAD:$BRANCH"
    redeploy_remote
    ;;
  ssh)
    ssh "$HOST_NAME"
    ;;
  *)
    echo "Usage: scripts/prod [status|health|reload|repair-sudo|redeploy|deploy|update|ssh]"
    exit 2
    ;;
esac
