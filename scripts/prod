#!/usr/bin/env bash
set -Eeuo pipefail

COMMAND="${1:-status}"
HOST_NAME="${JIM_PROD_SSH:-hp1}"
PROD_URL="${JIM_PROD_URL:-http://192.168.20.21:5101}"
REMOTE_ARCHIVE="${JIM_REMOTE_ARCHIVE:-/tmp/jim-site.tar.gz}"
REMOTE_WORK_DIR="${JIM_REMOTE_WORK_DIR:-~/jim-site-deploy}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCAL_ARCHIVE="$REPO_DIR/deploy/dist/jim-site.tar.gz"
SSH_CONFIG="$REPO_DIR/deploy/dist/jim-ssh-config"

SUDO_HELP="Prod sudo permissions may need to be refreshed. Run: bash scripts/prod setup"

ensure_ssh_config() {
  mkdir -p "$(dirname "$SSH_CONFIG")"
  cat > "$SSH_CONFIG" <<EOF
Host hp1
  HostName 192.168.20.21
  User leo
  StrictHostKeyChecking accept-new

Host hp4
  HostName 192.168.20.24
  User leo
  StrictHostKeyChecking accept-new

Host *
  StrictHostKeyChecking accept-new
EOF
}

prod_ssh() {
  ensure_ssh_config
  ssh -F "$SSH_CONFIG" "$HOST_NAME" "$@"
}

run_remote() {
  local command="$1"

  if ! prod_ssh "$command"; then
    echo
    echo "$SUDO_HELP"
    return 1
  fi
}

redeploy_remote() {
  run_remote "sudo -n /usr/local/sbin/jim-site-apply-deploy $REMOTE_ARCHIVE"
}

package_and_copy() {
  cd "$REPO_DIR"
  bash deploy/package-for-ubuntu.sh
  ensure_ssh_config
  scp -F "$SSH_CONFIG" "$LOCAL_ARCHIVE" "$HOST_NAME:$REMOTE_ARCHIVE"
}

deploy_package() {
  package_and_copy
  redeploy_remote
}

setup_remote() {
  package_and_copy
  ensure_ssh_config
  ssh -F "$SSH_CONFIG" -t "$HOST_NAME" "rm -rf $REMOTE_WORK_DIR && mkdir -p $REMOTE_WORK_DIR && tar -xzf $REMOTE_ARCHIVE -C $REMOTE_WORK_DIR && cd $REMOTE_WORK_DIR && sudo bash deploy/ubuntu/bootstrap.sh && sudo bash deploy/apply-deploy.sh $REMOTE_ARCHIVE"
}

show_status() {
  python3 - "$PROD_URL" <<'PY'
import sys
import urllib.request

url = sys.argv[1]
try:
    with urllib.request.urlopen(url, timeout=5) as response:
        print(f"Frontend: online ({response.status})")
        print(f"URL:      {url}")
except Exception as exc:
    print(f"Frontend is unreachable at {url}")
    print(exc)
    raise SystemExit(1)
PY
}

case "$COMMAND" in
  status|health)
    show_status
    ;;
  reload)
    run_remote "sudo /usr/sbin/nginx -t && sudo /usr/bin/systemctl reload nginx"
    echo "Nginx reloaded."
    ;;
  repair-sudo)
    run_remote "sudo /usr/local/sbin/jim-site-install-system-config"
    echo "Prod sudo permissions refreshed."
    ;;
  redeploy)
    redeploy_remote
    ;;
  setup|bootstrap)
    setup_remote
    ;;
  deploy|update)
    deploy_package
    ;;
  ssh)
    ensure_ssh_config
    ssh -F "$SSH_CONFIG" "$HOST_NAME"
    ;;
  *)
    echo "Usage: scripts/prod [status|health|reload|repair-sudo|redeploy|setup|bootstrap|deploy|update|ssh]"
    exit 2
    ;;
esac

